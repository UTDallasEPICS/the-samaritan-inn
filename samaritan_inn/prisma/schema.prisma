// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post{ 
  id String @id @default(cuid())
  name String
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("resident") // e.g., "resident", "staff", "admin"
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  appointments  Appointment[]
  classSignups  ClassSignup[]
  extendedCurfewRequests ExtendedCurfewRequest[]
  passRequests           PassRequest[]
  workSchedules          WorkSchedule[]
}

model Appointment {
  id          String    @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Class {
  id          String    @id @default(cuid())
  title       String
  description String?
  instructor  String
  startTime   DateTime
  endTime     DateTime
  location    String?
  capacity    Int
  signups     ClassSignup[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ClassSignup {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([classId, userId])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  author    String
  important Boolean  @default(false)
  date      String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Event {
  id        String   @id @default(cuid())
  title     String
  content   String
  author    String
  startDate DateTime
  endDate   DateTime
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
}

// ─── Enums for pass form models ─────────────────────────────────────────────

enum FormStatus {
  PENDING
  APPROVED
  DENIED
}

enum EmploymentStatus {
  EMPLOYED
  UNEMPLOYED
}

enum Transportation {
  WALK
  BIKE
  OWN_CAR
  RIDE
}

// ─── Extended Curfew Request ─────────────────────────────────────────────────

model ExtendedCurfewRequest {
  id                     String     @id @default(cuid())

  // Resident-filled
  todayDate              DateTime
  residentName           String
  datesNeeded            String
  expectedReturnTime     String
  isOngoing              Boolean    @default(false)
  reason                 String
  choreCoveredById       String?
  choreCoverageSignature String?
  residentSignature      String

  // Admin-only (caseworker/staff = admin role)
  adminName              String?
  status                 FormStatus @default(PENDING)
  adminSignature         String?
  decisionDate           DateTime?
  commentsNotes          String?
  receivedDate           DateTime?
  adminInitials          String?

  // Assignment
  assignedCaseworkerId   String?

  // Metadata
  userId                 String
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  submittedAt            DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

// ─── Resident Pass Request ───────────────────────────────────────────────────

model PassRequest {
  id                     String     @id @default(cuid())

  // Resident-filled
  residentName           String
  todayDate              DateTime
  datesRequested         String
  reason                 String
  choreCoveredById       String?
  choreCoverageSignature String?
  residentSignature      String
  signatureDate          DateTime

  // Admin-only (caseworker/staff = admin role)
  adminName              String?
  status                 FormStatus @default(PENDING)
  adminSignature         String?
  decisionDate           DateTime?
  
  // Assignment
  assignedCaseworkerId   String?

  // Metadata
  userId                 String
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  submittedAt            DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

// ─── Work Schedule ───────────────────────────────────────────────────────────

model WorkSchedule {
  id                  String           @id @default(cuid())

  // Resident-filled
  residentName        String
  room                String
  employmentStatus    EmploymentStatus
  employerName        String?
  employerLocation    String?
  weekOf              DateTime
  monthOf             String
  transportation      Transportation
  estimatedTravelTime String
  residentSignature   String
  signatureDate       DateTime
  days                WorkScheduleDay[]

  // Admin-only
  enteredByInitials   String?

  // Metadata
  userId              String
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  submittedAt         DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model WorkScheduleDay {
  id         String       @id @default(cuid())
  scheduleId String
  schedule   WorkSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  dayOfWeek  String       // "Monday" | "Tuesday" | ... | "Sunday"
  date       DateTime?
  startTime  String?      // e.g. "09:00 AM"
  endTime    String?      // e.g. "05:00 PM"

  @@unique([scheduleId, dayOfWeek])
}
